generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model Internacao {
  id               String   @id @default(cuid())
  petNome          String
  especie          String
  tutorNome        String
  entradaEm        DateTime @default(now())
  status           String   @default("estavel")
  proximaMedicacao String
  observacao       String   @default("")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}
